            <title>vivo 蔡司增距镜适配说明发布，G2 Ultra 正适配 X300 Pro / X200 Ultra 手机</title>
            <link>https://www.ithome.com/0/935/100.htm</link>
            <guid isPermaLink="false">https://www.ithome.com/0/935/100.htm</guid>
            <pubDate></pubDate>
            <updated>Wed, 01 Apr 2026 13:20:21 GMT</updated>
                
                
            <content:encoded>
