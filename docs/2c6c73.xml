        <item>
            <id>https://www.ithome.com/0/951/109.htm</id>
            <title>25kPa 大吸力 + 95℃ 高温自清洁：石头 A30 Pro 2.0 洗地机 1973 元国补新低</title>
            <link>https://www.ithome.com/0/951/109.htm</link>
            <guid isPermaLink="false">https://www.ithome.com/0/951/109.htm</guid>
            <pubDate></pubDate>
            <updated>Fri, 15 May 2026 11:55:11 GMT</updated>
                
                
            <content:encoded>
                <![CDATA[
                    
