        <item>
            <id>https://www.ithome.com/0/971/379.htm</id>
            <title>泰坦军团“战魂 KG277V PLUS”27 英寸显示器发售：4K 165Hz / FHD 520Hz 双模，1888 元</title>
            <link>https://www.ithome.com/0/971/379.htm</link>
            <guid isPermaLink="false">https://www.ithome.com/0/971/379.htm</guid>
            <pubDate></pubDate>
            <updated>Wed, 01 Jul 2026 14:10:46 GMT</updated>
                
                
            <content:encoded>
                <![CDATA[
                    
