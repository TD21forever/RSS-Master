        <item>
            <id>https://lapin.ithome.com/html/digi/947398.htm</id>
            <title>Vibram 黄金大底：迈乐迈行防水徒步鞋 799 → 249 元新补券（赠退货宝）</title>
            <link>https://lapin.ithome.com/html/digi/947398.htm</link>
            <guid isPermaLink="false">https://lapin.ithome.com/html/digi/947398.htm</guid>
            <pubDate></pubDate>
            <updated>Thu, 07 May 2026 11:34:53 GMT</updated>
                
                
            <content:encoded>
                <![CDATA[
                    
