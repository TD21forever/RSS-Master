        <item>
            <id>https://lapin.ithome.com/html/digi/967639.htm</id>
            <title>味道还不错：法丽兹夹心曲奇 3 元 / 包久违发车（商超 4.4 元）</title>
            <link>https://lapin.ithome.com/html/digi/967639.htm</link>
            <guid isPermaLink="false">https://lapin.ithome.com/html/digi/967639.htm</guid>
            <pubDate></pubDate>
            <updated>Tue, 23 Jun 2026 11:30:07 GMT</updated>
                
                
